# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# For production Electron, the app sets this automatically to the userData path.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── GitHub Auto-Update (Electron) ─────────────────────────────────────────────
# GH_TOKEN       — Full repo access. Used only at BUILD TIME to publish releases.
#                  Never committed. Set in your terminal before running electron:publish.
#                  Create at: https://github.com/settings/tokens → Classic → scope: repo
# GH_READ_TOKEN  — Read-only token. Bundled INTO the app so it can download updates
#                  from the private repo at runtime. Bake it into your .env at build time.
#                  Create at: https://github.com/settings/tokens → Fine-grained →
#                  Repository: management-software-build → Contents: Read-only
GH_TOKEN="ghp_YOUR_FULL_ACCESS_TOKEN_HERE"
GH_READ_TOKEN="github_pat_YOUR_READ_ONLY_TOKEN_HERE"

# ── Optional integrations ─────────────────────────────────────────────────────
ETA_API_URL="https://eta.example.com/invoices"
ETA_API_KEY="replace-with-eta-api-key"
ETA_TIMEOUT_MS="10000"
