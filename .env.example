# =============================================================================
#  نظام إدارة المتجر — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains secrets.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  DATABASE  (Neon — free at neon.tech)
# ─────────────────────────────────────────────────────────────────────────────
#
#  How to get this:
#  1. Go to neon.tech → Sign up → Create a project (pick any name + region)
#  2. On the dashboard, click "Connection Details"
#  3. Make sure "Connection string" is selected (not pooled)
#  4. Copy the full string and paste it below
#
#  It looks like:
#  postgresql://neondb_owner:AbCdEfGh@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
#
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require"


# ─────────────────────────────────────────────────────────────────────────────
#  AUTHENTICATION  (NextAuth.js)
# ─────────────────────────────────────────────────────────────────────────────
#
#  NEXTAUTH_SECRET — A long random string used to sign session tokens.
#                    Generate one by running this in your terminal:
#                      openssl rand -hex 32
#                    Use the SAME value in local dev and in Vercel.
#                    If you change it later, all logged-in users get signed out.
#
#  NEXTAUTH_URL    — The full URL where the app is running.
#                    • Local dev:  http://localhost:3000
#                    • Production: https://your-app.vercel.app
#                    Must match exactly — no trailing slash.
#
NEXTAUTH_SECRET="paste-the-output-of-openssl-rand-hex-32-here"
NEXTAUTH_URL="http://localhost:3000"


# ─────────────────────────────────────────────────────────────────────────────
#  ETA INTEGRATION  (Egyptian Tax Authority — optional)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Only needed if you submit e-invoices to the Egyptian Tax Authority.
#  Leave the values empty if you don't use this — the feature just won't run.
#
ETA_API_URL=""
ETA_API_KEY=""
ETA_TIMEOUT_MS="10000"
