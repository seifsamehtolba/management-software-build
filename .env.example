# =============================================================================
#  نظام إدارة المتجر — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains secrets.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  DATABASE  (Supabase — free at supabase.com)
# ─────────────────────────────────────────────────────────────────────────────
#
#  How to get these:
#  1. Go to supabase.com → New Project → choose name + password
#  2. Wait ~2 min for it to spin up
#  3. Go to: Project Settings → Database → Connection string
#  4. Select "Transaction" mode → copy the URL → paste as DATABASE_URL
#  5. Select "Session" mode    → copy the URL → paste as DIRECT_URL
#
#  DATABASE_URL  — Used by the app at runtime (goes through connection pooler,
#                  handles many simultaneous connections safely on Vercel)
#  DIRECT_URL    — Used only by `prisma migrate` to apply schema changes
#                  (bypasses the pooler, needed for migrations)
#
DATABASE_URL="postgresql://postgres.lsvwklsayghhnqbhjhks:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-YOURREGION.supabase.com:5432/postgres"


# ─────────────────────────────────────────────────────────────────────────────
#  AUTHENTICATION  (NextAuth.js)
# ─────────────────────────────────────────────────────────────────────────────
#
#  NEXTAUTH_SECRET — A long random string used to sign session tokens.
#                    Generate one by running this in your terminal:
#                      openssl rand -hex 32
#                    Use the SAME secret in local dev and in Vercel.
#                    If you change it, all logged-in users get signed out.
#
#  NEXTAUTH_URL    — The full URL where the app is running.
#                    • Local dev:  http://localhost:3000
#                    • Production: https://your-app.vercel.app
#                    Must match exactly — no trailing slash.
#
NEXTAUTH_SECRET="paste-the-output-of-openssl-rand-hex-32-here"
NEXTAUTH_URL="http://localhost:3000"


# ─────────────────────────────────────────────────────────────────────────────
#  ETA INTEGRATION  (Egyptian Tax Authority — optional)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Only needed if you submit e-invoices to the Egyptian Tax Authority.
#  Leave blank or remove these lines if you don't use ETA.
#
#  ETA_API_URL    — The endpoint provided by your ETA integrator / portal
#  ETA_API_KEY    — Your API key from the ETA portal
#  ETA_TIMEOUT_MS — How long to wait for ETA to respond before giving up
#                   Default is 10000 (10 seconds). Increase if you get timeouts.
#
ETA_API_URL=""
ETA_API_KEY=""
ETA_TIMEOUT_MS="10000"
