# Local PostgreSQL (Docker) — copy this file to .env.local
# .env.local overrides .env automatically in Next.js

DATABASE_URL="postgresql://storeuser:storepassword@localhost:5432/storedb"
NEXTAUTH_SECRET="change-this-to-a-random-64-char-hex-string"
NEXTAUTH_URL="http://localhost:3000"
ETA_API_URL=""
ETA_API_KEY=""
ETA_TIMEOUT_MS="10000"
