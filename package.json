{
  "name": "hardware-store",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "finance:backfill": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/backfillFinanceCosting.ts",
    "electron:bundle": "node scripts/build-electron.mjs",
    "electron:dev": "node scripts/build-electron.mjs && electron dist-electron/main.js",
    "electron:build:win": "ELECTRON_BUILD=1 next build --webpack && node scripts/build-electron.mjs && electron-builder --win",
    "electron:build:mac": "ELECTRON_BUILD=1 next build --webpack && node scripts/build-electron.mjs && electron-builder --mac",
    "electron:publish:win": "node scripts/bake-update-token.mjs && ELECTRON_BUILD=1 next build --webpack && node scripts/build-electron.mjs && electron-builder --win --publish always",
    "electron:publish:mac": "node scripts/bake-update-token.mjs && ELECTRON_BUILD=1 next build --webpack && node scripts/build-electron.mjs && electron-builder --mac --publish always",
    "server:build": "next build --webpack",
    "server:package:mac": "node scripts/package-server.mjs --mac",
    "server:package:win": "node scripts/package-server.mjs --win",
    "server:build:mac": "next build --webpack && node scripts/package-server.mjs --mac",
    "server:build:win": "next build --webpack && node scripts/package-server.mjs --win"
  },
  "dependencies": {
    "@kbco/pcpartpicker": "^0.0.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.2.1",
    "dexie": "^4.4.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "next-pwa": "^5.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
